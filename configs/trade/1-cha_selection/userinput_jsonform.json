{
  "id": "trade-cha-selection--form",
  "title": "Initialize Consignment",
  "schema": {
    "type": "object",
    "properties": {
      "consignment_name": {
        "title": "Consignment Name",
        "type": "string",
        "maxLength": 255
      },
      "cha_company_id": {
        "title": "Select Customs House Agent",
        "type": "string",
        "oneOf": [
          {
            "const": "adam-pvt-ltd",
            "title": "ADAM PVT LTD"
          },
          {
            "const": "govtech",
            "title": "GovTech Company"
          },
          {
            "const": "piu",
            "title": "PIU Company"
          },
          {
            "const": "cda",
            "title": "CDA Company"
          },
          {
            "const": "npqs",
            "title": "NPQS Company"
          },
          {
            "const": "fcau",
            "title": "FCAU Company"
          }
        ]
      },
      "notifyRecipient": {
        "type": "string",
        "format": "email",
        "title": "Contact email for notifications",
        "example": "trader@example.lk"
      }
    },
    "required": [
      "consignment_name",
      "cha_company_id"
    ]
  },
  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      {
        "type": "Control",
        "scope": "#/properties/consignment_name"
      },
      {
        "type": "Control",
        "scope": "#/properties/cha_company_id"
      },
      {
        "type": "Control",
        "scope": "#/properties/notifyRecipient"
      }
    ]
  }
}