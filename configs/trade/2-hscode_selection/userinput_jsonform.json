{
  "id": "trade-hscode-selection--form",
  "title": "Select HS Codes",
  "schema": {
    "type": "object",
    "properties": {
      "hs_codes": {
        "type": "array",
        "title": "Select HS Codes",
        "items": {
          "type": "string",
          "oneOf": [
            {
              "const": "fcau-health-certificate-reg",
              "title": "FCAU Health Certificate (FCAU Flow)"
            },
            {
              "const": "npqs-export-phytosanitary-reg",
              "title": "NPQS Phyto Certificate (NPQS Flow)"
            },
            {
              "const": "cda-certificate-reg",
              "title": "CDA Coconut Certificate (CDA Flow)"
            }
          ]
        },
        "uniqueItems": true,
        "minItems": 1
      }
    },
    "required": [
      "hs_codes"
    ]
  },
  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      {
        "type": "Control",
        "scope": "#/properties/hs_codes"
      }
    ]
  }
}