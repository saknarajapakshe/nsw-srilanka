{
  "id": "cda-certificate-reg",
  "name": "CDA Export Coconut Certificate Registration",
  "version": 1,
  "nodes": [
    {
      "id": "start",
      "type": "START",
      "name": "Start"
    },
    {
      "id": "cda_1_0_apply",
      "type": "TASK",
      "name": "[CDA 1.0] Submit Application",
      "task_template_id": "cda-apply-coconut-cert-flow",
      "lane": "Trader/CHA",
      "input_mapping": {},
      "output_mapping": {
        "userform.cusdec_number": "cda.reference_number",
        "userform": "cda.userform"
      }
    },
    {
      "id": "cda_check_payment_gateway",
      "type": "GATEWAY",
      "gateway_type": "EXCLUSIVE_SPLIT",
      "name": "Is Payment Required?"
    },
    {
      "id": "cda_2_0_pay_fee",
      "type": "TASK",
      "name": "[CDA 2.0] Pay Application Fee",
      "task_template_id": "cda-pay-app-fee-flow",
      "lane": "Trader/CHA",
      "input_mapping": {
        "cda.reference_number": "reference_number",
        "cda.userform": "userform"
      },
      "output_mapping": {
        "payment_status": "cda.payment_status",
        "payment_receipt_url?": "cda.payment_receipt_url",
        "selected_method?": "cda.selected_method"
      }
    },
    {
      "id": "cda_3_0_review",
      "type": "TASK",
      "name": "[CDA 3.0] Wait on Review & Result",
      "task_template_id": "cda-review-result-flow",
      "lane": "CDA Officer",
      "input_mapping": {
        "cda.reference_number": "reference_number",
        "cda.userform": "userform",
        "cda.payment_receipt_url?": "payment_receipt_url",
        "cda.selected_method?": "selected_method"
      },
      "output_mapping": {
        "reviewerform.review_outcome": "cda.review_outcome",
        "reviewerform.certificate_id?": "cda.certificate_id",
        "reviewerform.certificate_file?": "cda.certificate_file"
      }
    },
    {
      "id": "cda_4_0_lot_adjustment",
      "type": "TASK",
      "name": "[CDA 4.0] Lot Adjustment",
      "task_template_id": "cda-lot-adjustment-flow",
      "lane": "Trader/CHA",
      "input_mapping": {
        "cda.reference_number": "reference_number",
        "cda.certificate_id": "certificate_id",
        "cda.certificate_file": "certificate_file",
        "cda.adjustment_feedback?": "adjustment_feedback"
      },
      "output_mapping": {
        "adjustment_choice": "cda.adjustment_choice",
        "certificate_file?": "cda.certificate_file"
      }
    },
    {
      "id": "cda_check_adjustment_completion",
      "type": "GATEWAY",
      "gateway_type": "EXCLUSIVE_SPLIT",
      "name": "Check Adjustment Completion"
    },
    {
      "id": "cda_5_0_view_new_certificate",
      "type": "TASK",
      "name": "[CDA 5.0] View Revised Certificate",
      "task_template_id": "cda-view-new-certificate-flow",
      "lane": "Trader/CHA",
      "input_mapping": {
        "cda.reference_number": "reference_number",
        "cda.certificate_id": "certificate_id",
        "cda.certificate_file": "certificate_file"
      },
      "output_mapping": {}
    },
    {
      "id": "end_success",
      "type": "END",
      "name": "Certificate Issued Successfully"
    }
  ],
  "edges": [
    {
      "id": "e_start_to_apply",
      "source_id": "start",
      "target_id": "cda_1_0_apply"
    },
    {
      "id": "e_apply_to_payment_gw",
      "source_id": "cda_1_0_apply",
      "target_id": "cda_check_payment_gateway"
    },
    {
      "id": "e_pay_required",
      "source_id": "cda_check_payment_gateway",
      "target_id": "cda_2_0_pay_fee",
      "condition": "cda.payment_status != 'success'"
    },
    {
      "id": "e_pay_bypass",
      "source_id": "cda_check_payment_gateway",
      "target_id": "cda_3_0_review",
      "condition": "cda.payment_status == 'success'"
    },
    {
      "id": "e_pay_to_review",
      "source_id": "cda_2_0_pay_fee",
      "target_id": "cda_3_0_review"
    },
    {
      "id": "e_review_to_lot_adj",
      "source_id": "cda_3_0_review",
      "target_id": "cda_4_0_lot_adjustment"
    },
    {
      "id": "e_lot_adj_to_gw",
      "source_id": "cda_4_0_lot_adjustment",
      "target_id": "cda_check_adjustment_completion"
    },
    {
      "id": "e_complete_app",
      "source_id": "cda_check_adjustment_completion",
      "target_id": "end_success",
      "condition": "cda.adjustment_choice == 'complete_application'"
    },
    {
      "id": "e_show_new_cert",
      "source_id": "cda_check_adjustment_completion",
      "target_id": "cda_5_0_view_new_certificate",
      "condition": "cda.adjustment_choice == 'request_lot_adjustment'"
    },
    {
      "id": "e_view_cert_to_success",
      "source_id": "cda_5_0_view_new_certificate",
      "target_id": "end_success"
    }
  ]
}
