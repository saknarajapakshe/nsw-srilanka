{
  "id": "cda-review-result--officer-form",
  "title": "CDA Officer Certificate Issuance",
  "schema": {
    "type": "object",
    "properties": {
      "review_outcome": {
        "type": "string",
        "title": "Review Assessment Outcome",
        "default": "approve",
        "example": "approve"
      },
      "certificate_id": {
        "type": "string",
        "title": "Generated Coconut Export Certificate ID",
        "example": "CERT-CDA-2026-08492"
      },
      "certificate_file": {
        "type": "string",
        "format": "file",
        "title": "Digital Coconut Export Certificate File (PDF)",
        "example": "https://cda.gov.lk/certs/CDA-EXP-2026-08492.pdf"
      }
    },
    "required": [
      "review_outcome",
      "certificate_id",
      "certificate_file"
    ]
  },
  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      {
        "type": "Group",
        "label": "Certificate Issuance Details",
        "elements": [
          {
            "type": "Control",
            "scope": "#/properties/certificate_id"
          },
          {
            "type": "Control",
            "scope": "#/properties/certificate_file"
          }
        ]
      }
    ]
  }
}