{
  "id": "cda-apply-coconut-cert-flow",
  "name": "Apply for Export Coconut Certificate",
  "version": 1,
  "nodes": [
    {
      "id": "start",
      "type": "START"
    },
    {
      "id": "applicant_submission",
      "type": "TASK",
      "task_template_id": "cda-apply-coconut-cert--user-input",
      "input_mapping": {
        "rejection_reason?": "rejection_reason"
      },
      "output_mapping": {
        "exporter_details": "userform.exporter_details",
        "cusdec_number": "userform.cusdec_number",
        "hs_code?": "userform.hs_code",
        "contract_number?": "userform.contract_number",
        "lot_number?": "userform.lot_number",
        "dc_grades": "userform.dc_grades",
        "date_of_containerization?": "userform.date_of_containerization",
        "vessel_name?": "userform.vessel_name",
        "container_number?": "userform.container_number",
        "date_of_sailing?": "userform.date_of_sailing",
        "port_of_discharge": "userform.port_of_discharge",
        "final_destination": "userform.final_destination",
        "buyer_name?": "userform.buyer_name",
        "container_filling_status": "userform.container_filling_status",
        "balance_material_nature?": "userform.balance_material_nature",
        "req_cert_salmonella?": "userform.req_cert_salmonella",
        "req_cert_physical?": "userform.req_cert_physical",
        "uploaded_dc_bags_details": "userform.uploaded_dc_bags_details"
      }
    },
    {
      "id": "officer_verification",
      "type": "TASK",
      "task_template_id": "cda-apply-coconut-cert--officer-verification",
      "input_mapping": {
        "userform": "submission"
      },
      "output_mapping": {
        "verification_outcome": "verificationform.verification_outcome",
        "rejection_reason?": "rejection_reason"
      }
    },
    {
      "id": "verification_gateway",
      "type": "GATEWAY",
      "gateway_type": "EXCLUSIVE_SPLIT"
    },
    {
      "id": "end",
      "type": "END"
    }
  ],
  "edges": [
    {
      "id": "e1",
      "source_id": "start",
      "target_id": "applicant_submission"
    },
    {
      "id": "e2",
      "source_id": "applicant_submission",
      "target_id": "officer_verification"
    },
    {
      "id": "e3",
      "source_id": "officer_verification",
      "target_id": "verification_gateway"
    },
    {
      "id": "e_needs_info",
      "source_id": "verification_gateway",
      "target_id": "applicant_submission",
      "condition": "verificationform.verification_outcome == 'needs_more_info'"
    },
    {
      "id": "e_approve",
      "source_id": "verification_gateway",
      "target_id": "end",
      "condition": "verificationform.verification_outcome == 'approve'"
    }
  ]
}