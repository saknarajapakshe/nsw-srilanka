{
  "id": "fcau-apply-health-cert--reviewer-form",
  "title": "Application Assessment Review",
  "schema": {
    "type": "object",
    "properties": {
      "application_review_outcome": {
        "type": "string",
        "title": "Application Assessment Outcome",
        "oneOf": [
          {
            "const": "approve",
            "title": "Approve"
          },
          {
            "const": "needs_more_info",
            "title": "Needs More Information"
          }
        ],
        "default": "approve",
        "example": "approve"
      },
      "sample_inspection_required": {
        "type": "boolean",
        "title": "Initial Sample Inspection Required",
        "default": false
      },
      "lab_test_required": {
        "type": "boolean",
        "title": "Upfront Laboratory Test Required",
        "default": false
      },
      "warehouse_inspection_required": {
        "type": "boolean",
        "title": "Warehouse Visual Inspection Required",
        "default": false
      },
      "reference_number": {
        "type": "string",
        "title": "FCAU Application Reference Number",
        "example": "REF-FCAU-2026-00481"
      },
      "rejection_reason": {
        "type": "string",
        "title": "Comments / Feedback / Deficiencies (if Needs Info)",
        "example": "Consignment food grade manufacturing details verified; application is complete and approved for fee assessment."
      }
    },
    "required": [
      "application_review_outcome"
    ],
    "allOf": [
      {
        "if": {
          "properties": {
            "application_review_outcome": {
              "const": "approve"
            }
          },
          "required": [
            "application_review_outcome"
          ]
        },
        "then": {
          "required": [
            "reference_number"
          ]
        }
      },
      {
        "if": {
          "properties": {
            "application_review_outcome": {
              "const": "needs_more_info"
            }
          },
          "required": [
            "application_review_outcome"
          ]
        },
        "then": {
          "required": [
            "rejection_reason"
          ]
        }
      }
    ]
  },
  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      {
        "type": "Control",
        "scope": "#/properties/application_review_outcome"
      },
      {
        "type": "Control",
        "scope": "#/properties/sample_inspection_required"
      },
      {
        "type": "Control",
        "scope": "#/properties/lab_test_required"
      },
      {
        "type": "Control",
        "scope": "#/properties/warehouse_inspection_required"
      },
      {
        "type": "Control",
        "scope": "#/properties/reference_number",
        "rule": {
          "effect": "SHOW",
          "condition": {
            "scope": "#/properties/application_review_outcome",
            "schema": {
              "const": "approve"
            }
          }
        }
      },
      {
        "type": "Control",
        "scope": "#/properties/rejection_reason",
        "rule": {
          "effect": "SHOW",
          "condition": {
            "scope": "#/properties/application_review_outcome",
            "schema": {
              "const": "needs_more_info"
            }
          }
        }
      }
    ]
  }
}