{
  "id": "fcau-apply-health-cert-flow",
  "name": "Apply for Health Certificate",
  "version": 1,
  "nodes": [
    {
      "id": "start",
      "type": "START"
    },
    {
      "id": "applicant_submission",
      "type": "TASK",
      "task_template_id": "fcau-apply-health-cert--user-input",
      "input_mapping": {},
      "output_mapping": {
        "exporter_name": "userform.exporter_name",
        "exporter_address": "userform.exporter_address",
        "consignee_name": "userform.consignee_name",
        "consignee_address": "userform.consignee_address",
        "description_of_food": "userform.description_of_food",
        "intended_export_date": "userform.intended_export_date",
        "lc_number": "userform.lc_number",
        "container_numbers": "userform.container_numbers",
        "vessel_name": "userform.vessel_name",
        "consignment_storage_address": "userform.consignment_storage_address",
        "package_batch_weight_details": "userform.package_batch_weight_details",
        "ingredients_details": "userform.ingredients_details",
        "in_house_quality_monitoring": "userform.in_house_quality_monitoring",
        "analysis_certificates": "userform.analysis_certificates",
        "other_declarations": "userform.other_declarations"
      }
    },
    {
      "id": "officer_review",
      "type": "TASK",
      "task_template_id": "fcau-apply-health-cert--external-review",
      "input_mapping": {
        "userform": "submission"
      },
      "output_mapping": {
        "application_review_outcome": "reviewerform.application_review_outcome",
        "sample_inspection_required": "reviewerform.sample_inspection_required",
        "lab_test_required": "reviewerform.lab_test_required",
        "warehouse_inspection_required": "reviewerform.warehouse_inspection_required",
        "reference_number?": "reviewerform.reference_number",
        "rejection_reason?": "reviewerform.rejection_reason"
      }
    },
    {
      "id": "review_gateway",
      "type": "GATEWAY",
      "gateway_type": "EXCLUSIVE_SPLIT"
    },
    {
      "id": "end",
      "type": "END"
    }
  ],
  "edges": [
    {
      "id": "e1",
      "source_id": "start",
      "target_id": "applicant_submission"
    },
    {
      "id": "e2",
      "source_id": "applicant_submission",
      "target_id": "officer_review"
    },
    {
      "id": "e3",
      "source_id": "officer_review",
      "target_id": "review_gateway"
    },
    {
      "id": "e_approve",
      "source_id": "review_gateway",
      "target_id": "end",
      "condition": "reviewerform.application_review_outcome == 'approve'"
    },
    {
      "id": "e_needs_info",
      "source_id": "review_gateway",
      "target_id": "applicant_submission",
      "condition": "reviewerform.application_review_outcome == 'needs_more_info'"
    }
  ]
}