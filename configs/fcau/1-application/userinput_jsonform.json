{
  "id": "fcau-apply-health-cert--user-form",
  "title": "FCAU Health Certificate Application",
  "schema": {
    "type": "object",
    "properties": {
      "exporter_name": {
        "type": "string",
        "title": "Name of Applicant",
        "example": "ACME Premium Food Exports Ltd."
      },
      "exporter_address": {
        "type": "string",
        "title": "Address of Applicant",
        "example": "No 18, Galle Road, Colombo 03, Sri Lanka"
      },
      "consignee_name": {
        "type": "string",
        "title": "Name of Consignee",
        "example": "Hamburg Fine Foods Import GMBH"
      },
      "consignee_address": {
        "type": "string",
        "title": "Address of Consignee",
        "example": "Industriestrasse 104, 20457 Hamburg, Germany"
      },
      "description_of_food": {
        "type": "string",
        "title": "Description of consignment and quantity",
        "example": "Premium Organic Coconut Cream, canned (400ml) - 500 Cartons, 5400 kg Total Net Weight"
      },
      "intended_export_date": {
        "type": "string",
        "format": "date",
        "title": "Date of intended export",
        "example": "2026-06-15"
      },
      "lc_number": {
        "type": "string",
        "title": "L/C No",
        "example": "LC-88392-COL"
      },
      "container_numbers": {
        "type": "string",
        "title": "Container Numbers (attach list if necessary)",
        "example": "MSCU-849201-9, GATU-102938-2"
      },
      "vessel_name": {
        "type": "string",
        "title": "Name of Vessel/ Number",
        "example": "CMA CGM MARCO POLO / V092"
      },
      "consignment_storage_address": {
        "type": "string",
        "title": "Address where consignment is stored",
        "example": "ACME Cold Storage, Sector 4, Export Zone, Biyagama"
      },
      "package_batch_weight_details": {
        "type": "string",
        "title": "Type of Package, Batch Codes and Total weight",
        "example": "Cans in Corrugated Cartons, Batch CC-2026-94, Total Net Weight 5400 kg"
      },
      "ingredients_details": {
        "type": "string",
        "title": "Details of ingredients used in product",
        "example": "Organic Coconut Extract (99.8%), Xanthan Gum (0.2%)"
      },
      "in_house_quality_monitoring": {
        "type": "string",
        "title": "Details of in-house quality monitoring",
        "example": "Daily microbiological sampling, temperature control monitoring, and HACCP CCP verification logs."
      },
      "analysis_certificates": {
        "type": "string",
        "format": "file",
        "title": "Raw Materials & Product Analysis Certificates"
      },
      "other_declarations": {
        "type": "string",
        "title": "Any other Declarations",
        "example": "Non-GMO certified, radiation-free consignment."
      }
    },
    "required": [
      "exporter_name",
      "exporter_address",
      "consignee_name",
      "consignee_address",
      "description_of_food",
      "intended_export_date",
      "lc_number",
      "container_numbers",
      "vessel_name",
      "consignment_storage_address",
      "package_batch_weight_details",
      "ingredients_details",
      "in_house_quality_monitoring",
      "analysis_certificates"
    ]
  },
  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      {
        "type": "Group",
        "label": "1. Consignment Details",
        "elements": [
          {
            "type": "HorizontalLayout",
            "elements": [
              {
                "type": "Control",
                "scope": "#/properties/exporter_name"
              },
              {
                "type": "Control",
                "scope": "#/properties/consignee_name"
              }
            ]
          },
          {
            "type": "HorizontalLayout",
            "elements": [
              {
                "type": "Control",
                "scope": "#/properties/exporter_address"
              },
              {
                "type": "Control",
                "scope": "#/properties/consignee_address"
              }
            ]
          }
        ]
      },
      {
        "type": "Group",
        "label": "2. Transport & Export Details",
        "elements": [
          {
            "type": "HorizontalLayout",
            "elements": [
              {
                "type": "Control",
                "scope": "#/properties/intended_export_date"
              },
              {
                "type": "Control",
                "scope": "#/properties/lc_number"
              }
            ]
          },
          {
            "type": "HorizontalLayout",
            "elements": [
              {
                "type": "Control",
                "scope": "#/properties/container_numbers"
              },
              {
                "type": "Control",
                "scope": "#/properties/vessel_name"
              }
            ]
          }
        ]
      },
      {
        "type": "Group",
        "label": "3. Items & Specifications",
        "elements": [
          {
            "type": "Control",
            "scope": "#/properties/description_of_food"
          },
          {
            "type": "Control",
            "scope": "#/properties/consignment_storage_address"
          },
          {
            "type": "Control",
            "scope": "#/properties/package_batch_weight_details"
          }
        ]
      },
      {
        "type": "Group",
        "label": "4. Quality & Declarations",
        "elements": [
          {
            "type": "Control",
            "scope": "#/properties/ingredients_details",
            "options": {
              "multi": true
            }
          },
          {
            "type": "Control",
            "scope": "#/properties/in_house_quality_monitoring",
            "options": {
              "multi": true
            }
          },
          {
            "type": "Control",
            "scope": "#/properties/analysis_certificates"
          },
          {
            "type": "Control",
            "scope": "#/properties/other_declarations",
            "options": {
              "multi": true
            }
          }
        ]
      }
    ]
  }
}
