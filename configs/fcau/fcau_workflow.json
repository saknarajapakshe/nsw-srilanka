{
  "id": "fcau-health-certificate-reg",
  "name": "FCAU Export Consignment & Health Certificate Registration",
  "version": 18,
  "nodes": [
    {
      "id": "start",
      "type": "START",
      "name": "Start Entry Point"
    },
    {
      "id": "fcau_1_0_apply",
      "type": "TASK",
      "name": "[FCAU 1.0/1.1] Submit & Assess Application",
      "task_template_id": "fcau-apply-health-cert-flow",
      "lane": "FCAU Officer/NSW System",
      "input_mapping": {},
      "output_mapping": {
        "reviewerform.application_review_outcome": "fcau.application_review_outcome",
        "reviewerform.sample_inspection_required": "fcau.sample_inspection_required",
        "reviewerform.lab_test_required": "fcau.lab_test_required",
        "reviewerform.warehouse_inspection_required": "fcau.warehouse_inspection_required",
        "reviewerform.reference_number": "fcau.reference_number",
        "userform": "fcau.userform"
      }
    },
    {
      "id": "fcau_application_gateway",
      "type": "GATEWAY",
      "gateway_type": "EXCLUSIVE_SPLIT",
      "name": "Is Application Satisfactory?"
    },
    {
      "id": "fcau_2_0_pay_fee",
      "type": "TASK",
      "name": "[FCAU 2.0] Pay Application Fee",
      "task_template_id": "fcau-pay-app-fee-flow",
      "lane": "Trader/CHA",
      "input_mapping": {
        "fcau.reference_number": "reference_number",
        "fcau.userform": "userform"
      },
      "output_mapping": {
        "payment_status": "fcau.app_fee_payment_status"
      }
    },
    {
      "id": "fcau_main_parallel_fork",
      "type": "GATEWAY",
      "gateway_type": "PARALLEL_SPLIT",
      "name": "Main Parallel Fork"
    },
    {
      "id": "fcau_gw_check_warehouse",
      "type": "GATEWAY",
      "gateway_type": "EXCLUSIVE_SPLIT",
      "name": "Evaluate Warehouse Requirement"
    },
    {
      "id": "fcau_3_1_schedule_warehouse",
      "type": "TASK",
      "name": "[FCAU 3.1] Inform Warehouse Inspection Date and Location",
      "task_template_id": "fcau-warehouse-scheduling-flow",
      "lane": "Trader/CHA",
      "input_mapping": {
        "fcau.reference_number": "reference_number",
        "fcau.userform": "userform"
      },
      "output_mapping": {
        "traderinput.inspection_date": "fcau.warehouse_inspection_date",
        "traderinput.warehouse_location": "fcau.warehouse_location"
      }
    },
    {
      "id": "fcau_3_2_warehouse_inspection",
      "type": "TASK",
      "name": "[FCAU 3.2] Conduct Warehouse Visual Inspection",
      "task_template_id": "fcau-warehouse-inspection-flow",
      "lane": "FCAU Officer/NSW System",
      "input_mapping": {
        "fcau.reference_number": "reference_number",
        "fcau.userform": "userform"
      },
      "output_mapping": {
        "inspection_outcome": "fcau.warehouse_inspection_outcome"
      }
    },
    {
      "id": "fcau_gw_warehouse_post_test",
      "type": "GATEWAY",
      "gateway_type": "EXCLUSIVE_SPLIT",
      "name": "Evaluate Post-Warehouse Lab Requirement"
    },
    {
      "id": "fcau_6_0_pay_post_wh_lab_fee",
      "type": "TASK",
      "name": "[FCAU 6.0-POST] Pay Post-Warehouse Lab Fee & Upload Receipt",
      "task_template_id": "fcau-pay-post-wh-lab-fee-flow",
      "lane": "Trader/CHA",
      "input_mapping": {
        "fcau.reference_number": "reference_number",
        "fcau.userform": "userform"
      },
      "output_mapping": {
        "post_wh_lab_payment_status": "fcau.post_wh_lab_fee_payment_status"
      }
    },
    {
      "id": "fcau_7_0_wait_post_wh_lab_results",
      "type": "TASK",
      "name": "[FCAU 7.0-POST] Wait on Post-Warehouse Lab Results",
      "task_template_id": "fcau-post-wh-lab-testing-flow",
      "lane": "FCAU Officer/NSW System",
      "input_mapping": {
        "fcau.reference_number": "reference_number",
        "fcau.userform": "userform"
      },
      "output_mapping": {
        "post_wh_lab_outcome": "fcau.post_wh_lab_test_outcome"
      }
    },
    {
      "id": "fcau_join_warehouse_branch",
      "type": "GATEWAY",
      "gateway_type": "EXCLUSIVE_JOIN",
      "name": "Merge Warehouse Branch"
    },
    {
      "id": "fcau_gw_check_sample_flow",
      "type": "GATEWAY",
      "gateway_type": "EXCLUSIVE_SPLIT",
      "name": "Evaluate Initial Sample Testing Flow Requirement"
    },
    {
      "id": "fcau_4_1_sample_collection",
      "type": "TASK",
      "name": "[FCAU 4.1/4.2] Submit, Receive and Number Sample",
      "task_template_id": "fcau-sample-collection-flow",
      "lane": "Trader & FCAU Officer",
      "input_mapping": {
        "fcau.reference_number": "reference_number",
        "fcau.userform": "userform"
      },
      "output_mapping": {
        "generated_number.initial_sample": "fcau.initial_sample_number"
      }
    },
    {
      "id": "fcau_sub_parallel_test_fork",
      "type": "GATEWAY",
      "gateway_type": "PARALLEL_SPLIT",
      "name": "Sub-Parallel Testing Fork"
    },
    {
      "id": "fcau_gw_check_visual_test",
      "type": "GATEWAY",
      "gateway_type": "EXCLUSIVE_SPLIT",
      "name": "Is Visual Sample Inspection Required?"
    },
    {
      "id": "fcau_5_1_visual_assessment",
      "type": "TASK",
      "name": "[FCAU 5.1] Assess Sample Manually",
      "task_template_id": "fcau-visual-assessment-flow",
      "lane": "FCAU Officer/NSW System",
      "input_mapping": {
        "fcau.reference_number": "reference_number",
        "fcau.userform": "userform"
      },
      "output_mapping": {
        "visual_outcome": "fcau.visual_inspection_outcome"
      }
    },
    {
      "id": "fcau_gw_visual_outcome_split",
      "type": "GATEWAY",
      "gateway_type": "EXCLUSIVE_SPLIT",
      "name": "Evaluate Visual Assessment Outcome"
    },
    {
      "id": "fcau_join_visual_branch",
      "type": "GATEWAY",
      "gateway_type": "EXCLUSIVE_JOIN",
      "name": "Merge Visual Branch"
    },
    {
      "id": "fcau_gw_check_lab_test",
      "type": "GATEWAY",
      "gateway_type": "EXCLUSIVE_SPLIT",
      "name": "Is Lab Test Required Upfront?"
    },
    {
      "id": "fcau_join_lab_payment_pre",
      "type": "GATEWAY",
      "gateway_type": "EXCLUSIVE_JOIN",
      "name": "Lab Payment Entry Merge Point"
    },
    {
      "id": "fcau_6_0_pay_lab_test_fee",
      "type": "TASK",
      "name": "[FCAU 6.0] Pay Lab Test Fee & Upload Receipt",
      "task_template_id": "fcau-pay-lab-fee-flow",
      "lane": "Trader/CHA",
      "input_mapping": {
        "fcau.reference_number": "reference_number",
        "fcau.userform": "userform"
      },
      "output_mapping": {
        "lab_payment_status": "fcau.lab_fee_payment_status"
      }
    },
    {
      "id": "fcau_7_0_wait_lab_results",
      "type": "TASK",
      "name": "[FCAU 7.0] Wait on Lab Results",
      "task_template_id": "fcau-lab-testing-flow",
      "lane": "FCAU Officer/NSW System",
      "input_mapping": {
        "fcau.reference_number": "reference_number",
        "fcau.userform": "userform"
      },
      "output_mapping": {
        "lab_outcome": "fcau.lab_test_outcome"
      }
    },
    {
      "id": "fcau_join_lab_branch",
      "type": "GATEWAY",
      "gateway_type": "EXCLUSIVE_JOIN",
      "name": "Merge Lab Branch"
    },
    {
      "id": "fcau_sub_parallel_test_join",
      "type": "GATEWAY",
      "gateway_type": "PARALLEL_JOIN",
      "name": "Synchronize Inner Testing Paths"
    },
    {
      "id": "fcau_join_sample_flow_branch",
      "type": "GATEWAY",
      "gateway_type": "EXCLUSIVE_JOIN",
      "name": "Merge Sample Flow Block and Bypass"
    },
    {
      "id": "fcau_main_parallel_join",
      "type": "GATEWAY",
      "gateway_type": "PARALLEL_JOIN",
      "name": "Synchronize All Root Parallel Branches"
    },
    {
      "id": "fcau_result_assessment_gateway",
      "type": "GATEWAY",
      "gateway_type": "EXCLUSIVE_SPLIT",
      "name": "Are Combined Test/Inspection Results Satisfactory?"
    },
    {
      "id": "fcau_8_0_issue_certificate",
      "type": "TASK",
      "name": "[FCAU 8.0] Issue Health Certificate",
      "task_template_id": "fcau-issue-certificate-flow",
      "lane": "FCAU Officer/NSW System",
      "input_mapping": {
        "fcau.reference_number": "reference_number",
        "fcau.userform": "userform"
      },
      "output_mapping": {}
    },
    {
      "id": "end_app_review_failed",
      "type": "END",
      "name": "End: Application Disapproved"
    },
    {
      "id": "end_verification_failed",
      "type": "END",
      "name": "End: Testing or Inspection Failures Found"
    },
    {
      "id": "end_workflow_success",
      "type": "END",
      "name": "End: Health Certificate Successfully Generated"
    }
  ],
  "edges": [
    {
      "id": "e_start_to_apply",
      "source_id": "start",
      "target_id": "fcau_1_0_apply"
    },
    {
      "id": "e_apply_to_gw",
      "source_id": "fcau_1_0_apply",
      "target_id": "fcau_application_gateway"
    },
    {
      "id": "e_gw_to_pay",
      "source_id": "fcau_application_gateway",
      "target_id": "fcau_2_0_pay_fee",
      "condition": "fcau.application_review_outcome == 'approve'"
    },
    {
      "id": "e_gw_to_reject_end",
      "source_id": "fcau_application_gateway",
      "target_id": "end_app_review_failed",
      "condition": "fcau.application_review_outcome == 'reject'"
    },
    {
      "id": "e_pay_to_main_parallel_fork",
      "source_id": "fcau_2_0_pay_fee",
      "target_id": "fcau_main_parallel_fork"
    },
    {
      "id": "e_main_fork_to_warehouse_gw",
      "source_id": "fcau_main_parallel_fork",
      "target_id": "fcau_gw_check_warehouse"
    },
    {
      "id": "e_main_fork_to_sample_flow_gw",
      "source_id": "fcau_main_parallel_fork",
      "target_id": "fcau_gw_check_sample_flow"
    },
    {
      "id": "e_warehouse_true",
      "source_id": "fcau_gw_check_warehouse",
      "target_id": "fcau_3_1_schedule_warehouse",
      "condition": "fcau.warehouse_inspection_required == true"
    },
    {
      "id": "e_warehouse_schedule_to_inspect",
      "source_id": "fcau_3_1_schedule_warehouse",
      "target_id": "fcau_3_2_warehouse_inspection"
    },
    {
      "id": "e_warehouse_bypass",
      "source_id": "fcau_gw_check_warehouse",
      "target_id": "fcau_join_warehouse_branch",
      "condition": "fcau.warehouse_inspection_required == false"
    },
    {
      "id": "e_warehouse_task_to_post_gw",
      "source_id": "fcau_3_2_warehouse_inspection",
      "target_id": "fcau_gw_warehouse_post_test"
    },
    {
      "id": "e_post_wh_test_required",
      "source_id": "fcau_gw_warehouse_post_test",
      "target_id": "fcau_6_0_pay_post_wh_lab_fee",
      "condition": "fcau.warehouse_inspection_outcome == 'lab_test_required'"
    },
    {
      "id": "e_post_wh_test_bypass",
      "source_id": "fcau_gw_warehouse_post_test",
      "target_id": "fcau_join_warehouse_branch",
      "condition": "fcau.warehouse_inspection_outcome != 'lab_test_required'"
    },
    {
      "id": "e_post_wh_fee_to_results",
      "source_id": "fcau_6_0_pay_post_wh_lab_fee",
      "target_id": "fcau_7_0_wait_post_wh_lab_results"
    },
    {
      "id": "e_post_wh_results_to_join",
      "source_id": "fcau_7_0_wait_post_wh_lab_results",
      "target_id": "fcau_join_warehouse_branch"
    },
    {
      "id": "e_warehouse_branch_to_main_join",
      "source_id": "fcau_join_warehouse_branch",
      "target_id": "fcau_main_parallel_join"
    },
    {
      "id": "e_sample_flow_true",
      "source_id": "fcau_gw_check_sample_flow",
      "target_id": "fcau_4_1_sample_collection",
      "condition": "fcau.sample_inspection_required == true || fcau.lab_test_required == true"
    },
    {
      "id": "e_sample_collection_to_sub_fork",
      "source_id": "fcau_4_1_sample_collection",
      "target_id": "fcau_sub_parallel_test_fork"
    },
    {
      "id": "e_sample_flow_bypass",
      "source_id": "fcau_gw_check_sample_flow",
      "target_id": "fcau_join_sample_flow_branch",
      "condition": "fcau.sample_inspection_required == false && fcau.lab_test_required == false"
    },
    {
      "id": "e_sub_fork_to_visual_gw",
      "source_id": "fcau_sub_parallel_test_fork",
      "target_id": "fcau_gw_check_visual_test"
    },
    {
      "id": "e_sub_fork_to_lab_gw",
      "source_id": "fcau_sub_parallel_test_fork",
      "target_id": "fcau_gw_check_lab_test"
    },
    {
      "id": "e_visual_run",
      "source_id": "fcau_gw_check_visual_test",
      "target_id": "fcau_5_1_visual_assessment",
      "condition": "fcau.sample_inspection_required == true"
    },
    {
      "id": "e_visual_bypass",
      "source_id": "fcau_gw_check_visual_test",
      "target_id": "fcau_join_visual_branch",
      "condition": "fcau.sample_inspection_required == false"
    },
    {
      "id": "e_visual_task_to_outcome_gw",
      "source_id": "fcau_5_1_visual_assessment",
      "target_id": "fcau_gw_visual_outcome_split"
    },
    {
      "id": "e_visual_to_lab_escalation",
      "source_id": "fcau_gw_visual_outcome_split",
      "target_id": "fcau_join_lab_payment_pre",
      "condition": "fcau.visual_inspection_outcome == 'lab_test_required'"
    },
    {
      "id": "e_visual_normal_flow",
      "source_id": "fcau_gw_visual_outcome_split",
      "target_id": "fcau_join_visual_branch",
      "condition": "fcau.visual_inspection_outcome != 'lab_test_required'"
    },
    {
      "id": "e_visual_branch_to_sub_join",
      "source_id": "fcau_join_visual_branch",
      "target_id": "fcau_sub_parallel_test_join"
    },
    {
      "id": "e_lab_run",
      "source_id": "fcau_gw_check_lab_test",
      "target_id": "fcau_join_lab_payment_pre",
      "condition": "fcau.lab_test_required == true"
    },
    {
      "id": "e_lab_bypass",
      "source_id": "fcau_gw_check_lab_test",
      "target_id": "fcau_join_lab_branch",
      "condition": "fcau.lab_test_required == false"
    },
    {
      "id": "e_lab_join_to_payment",
      "source_id": "fcau_join_lab_payment_pre",
      "target_id": "fcau_6_0_pay_lab_test_fee"
    },
    {
      "id": "e_lab_fee_to_diagnostics",
      "source_id": "fcau_6_0_pay_lab_test_fee",
      "target_id": "fcau_7_0_wait_lab_results"
    },
    {
      "id": "e_lab_task_to_join",
      "source_id": "fcau_7_0_wait_lab_results",
      "target_id": "fcau_join_lab_branch"
    },
    {
      "id": "e_lab_branch_to_sub_join",
      "source_id": "fcau_join_lab_branch",
      "target_id": "fcau_sub_parallel_test_join"
    },
    {
      "id": "e_sub_join_to_sample_flow_join",
      "source_id": "fcau_sub_parallel_test_join",
      "target_id": "fcau_join_sample_flow_branch"
    },
    {
      "id": "e_sample_flow_join_to_main_join",
      "source_id": "fcau_join_sample_flow_branch",
      "target_id": "fcau_main_parallel_join"
    },
    {
      "id": "e_main_join_to_assessment",
      "source_id": "fcau_main_parallel_join",
      "target_id": "fcau_result_assessment_gateway"
    },
    {
      "id": "e_assess_pass",
      "source_id": "fcau_result_assessment_gateway",
      "target_id": "fcau_8_0_issue_certificate",
      "condition": "(fcau.warehouse_inspection_required == false || fcau.warehouse_inspection_outcome == 'pass' || (fcau.warehouse_inspection_outcome == 'lab_test_required' && fcau.post_wh_lab_test_outcome == 'pass')) && (fcau.sample_inspection_required == false || fcau.visual_inspection_outcome == 'pass' || (fcau.visual_inspection_outcome == 'lab_test_required' && fcau.lab_test_outcome == 'pass')) && (fcau.lab_test_required == false || fcau.lab_test_outcome == 'pass')"
    },
    {
      "id": "e_assess_fail",
      "source_id": "fcau_result_assessment_gateway",
      "target_id": "end_verification_failed",
      "condition": "fcau.warehouse_inspection_outcome == 'fail' || fcau.post_wh_lab_test_outcome == 'fail' || fcau.visual_inspection_outcome == 'fail' || fcau.lab_test_outcome == 'fail'"
    },
    {
      "id": "e_certificate_to_success",
      "source_id": "fcau_8_0_issue_certificate",
      "target_id": "end_workflow_success"
    }
  ]
}