{
  "id": "fcau-pay-post-wh-lab-fee-flow",
  "name": "Pay Post-Warehouse Lab Test Fee",
  "version": 1,
  "nodes": [
    {
      "id": "start",
      "type": "START"
    },
    {
      "id": "upload_receipt_task",
      "type": "TASK",
      "task_template_id": "fcau-pay-post-wh-lab-fee--upload-receipt",
      "input_mapping": {
        "payment_feedback?": "payment_feedback"
      },
      "output_mapping": {
        "lab_receipt": "lab_receipt"
      }
    },
    {
      "id": "review_receipt_task",
      "type": "TASK",
      "task_template_id": "fcau-pay-post-wh-lab-fee--review-receipt",
      "input_mapping": {
        "reference_number": "reference_number",
        "lab_receipt": "lab_receipt"
      },
      "output_mapping": {
        "payment_review_outcome": "post_wh_lab_payment_status",
        "payment_feedback?": "payment_feedback"
      }
    },
    {
      "id": "review_gateway",
      "type": "GATEWAY",
      "gateway_type": "EXCLUSIVE_SPLIT"
    },
    {
      "id": "end",
      "type": "END"
    }
  ],
  "edges": [
    {
      "id": "e_start",
      "source_id": "start",
      "target_id": "upload_receipt_task"
    },
    {
      "id": "e_to_review",
      "source_id": "upload_receipt_task",
      "target_id": "review_receipt_task"
    },
    {
      "id": "e_to_gateway",
      "source_id": "review_receipt_task",
      "target_id": "review_gateway"
    },
    {
      "id": "e_needs_info",
      "source_id": "review_gateway",
      "target_id": "upload_receipt_task",
      "condition": "post_wh_lab_payment_status == 'needs_more_info'"
    },
    {
      "id": "e_approve",
      "source_id": "review_gateway",
      "target_id": "end",
      "condition": "post_wh_lab_payment_status == 'approve'"
    }
  ]
}
