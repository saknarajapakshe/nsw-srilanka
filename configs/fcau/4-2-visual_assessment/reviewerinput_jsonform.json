{
  "id": "fcau-visual-assessment--reviewer-form",
  "title": "Visual Sample Assessment Form",
  "schema": {
    "type": "object",
    "properties": {
      "visual_outcome": {
        "type": "string",
        "title": "Visual Inspection Outcome",
        "oneOf": [
          { "const": "pass", "title": "Pass - Satisfactory" },
          { "const": "lab_test_required", "title": "Lab Test Required" }
        ],
        "default": "pass"
      },
      "comments": {
        "type": "string",
        "title": "Manual Physical Assessment Comments"
      }
    },
    "required": ["visual_outcome"]
  },
  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      {
        "type": "Control",
        "scope": "#/properties/visual_outcome"
      },
      {
        "type": "Control",
        "scope": "#/properties/comments",
        "options": {
          "multi": true
        }
      }
    ]
  }
}
