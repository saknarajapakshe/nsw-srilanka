{
  "id": "fcau-issue-certificate--officer-form",
  "title": "Health Certificate Issuance",
  "schema": {
    "type": "object",
    "properties": {
      "certificate_id": {
        "type": "string",
        "title": "Generated Food Health Certificate ID",
        "example": "CERT-FCAU-ACME-9024"
      },
      "certificate": {
        "type": "string",
        "title": "Digital Certificate File Upload (PDF)",
        "format": "file"
      },
      "authorized_signature": {
        "type": "string",
        "title": "Approving Officer",
        "example": "DR. ANURA SILVA - CHIEF FOOD INSPECTOR"
      }
    },
    "required": [
      "certificate_id",
      "certificate",
      "authorized_signature"
    ]
  },
  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      {
        "type": "Control",
        "scope": "#/properties/certificate_id"
      },
      {
        "type": "Control",
        "scope": "#/properties/certificate"
      },
      {
        "type": "Control",
        "scope": "#/properties/authorized_signature"
      }
    ]
  }
}