{
  "id": "fcau-warehouse-inspection--officer-form",
  "title": "Warehouse Visual Inspection Outcome",
  "schema": {
    "type": "object",
    "properties": {
      "inspection_outcome": {
        "type": "string",
        "title": "Visual Inspection Result",
        "oneOf": [
          {
            "const": "pass",
            "title": "Passed (Satisfactory)"
          },
          {
            "const": "fail",
            "title": "Failed (Deficiencies Found)"
          },
          {
            "const": "lab_test_required",
            "title": "Requires Laboratory Testing"
          }
        ],
        "default": "pass",
        "example": "pass"
      },
      "inspection_comments": {
        "type": "string",
        "title": "Inspection Notes / Observations",
        "example": "Visual inspection of storage area completed. Food containers intact and temperature controlled."
      }
    },
    "required": [
      "inspection_outcome"
    ]
  },
  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      {
        "type": "Control",
        "scope": "#/properties/inspection_outcome"
      },
      {
        "type": "Control",
        "scope": "#/properties/inspection_comments"
      }
    ]
  }
}
