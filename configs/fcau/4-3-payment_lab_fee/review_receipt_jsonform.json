{
  "id": "fcau-pay-lab-fee--review-form",
  "title": "Laboratory Payment Receipt Review",
  "schema": {
    "type": "object",
    "properties": {
      "payment_review_outcome": {
        "type": "string",
        "title": "Verification Outcome",
        "oneOf": [
          {
            "const": "approve",
            "title": "Acknowledge Payment"
          },
          {
            "const": "needs_more_info",
            "title": "Needs More Information"
          }
        ],
        "default": "approve",
        "example": "approve"
      },
      "payment_feedback": {
        "type": "string",
        "title": "Officer Feedback / Deficiencies (Required if Needs Info)",
        "example": "The uploaded receipt is blurred. Please upload a clear copy."
      }
    },
    "required": [
      "payment_review_outcome"
    ],
    "if": {
      "properties": {
        "payment_review_outcome": {
          "const": "needs_more_info"
        }
      },
      "required": [
        "payment_review_outcome"
      ]
    },
    "then": {
      "required": [
        "payment_feedback"
      ]
    }
  },
  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      {
        "type": "Control",
        "scope": "#/properties/payment_review_outcome"
      },
      {
        "type": "Control",
        "scope": "#/properties/payment_feedback",
        "options": {
          "multiLine": true
        },
        "rule": {
          "effect": "SHOW",
          "condition": {
            "scope": "#/properties/payment_review_outcome",
            "schema": {
              "const": "needs_more_info"
            }
          }
        }
      }
    ]
  }
}
