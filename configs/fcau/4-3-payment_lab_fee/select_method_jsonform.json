{
  "id": "fcau-pay-lab-fee--select-method-form",
  "title": "Select Payment Gateway",
  "schema": {
    "type": "object",
    "required": [
      "selected_method"
    ],
    "properties": {
      "selected_method": {
        "type": "string",
        "title": "Payment Method",
        "default": "govpay",
        "oneOf": [
          {
            "const": "govpay",
            "title": "GovPay (Bank/ATM/Online) [Offline Instructions]"
          }
        ]
      }
    }
  },
  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      {
        "type": "Label",
        "text": "Please select the preferred payment method. The next screen will show you the payment amount and instructions for completing the payment."
      },
      {
        "type": "Control",
        "scope": "#/properties/selected_method"
      }
    ]
  }
}