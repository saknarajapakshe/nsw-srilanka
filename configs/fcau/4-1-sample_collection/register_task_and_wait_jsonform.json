{
  "id": "fcau-sample-collection--reviewer-form",
  "title": "Consignment Sample Receipt Confirmation",
  "schema": {
    "type": "object",
    "properties": {
      "initial_sample": {
        "type": "string",
        "title": "Issued Sample Number",
        "example": "SMP-FCAU-2026-948"
      },
      "received_at": {
        "type": "string",
        "format": "date",
        "title": "Date of Receipt",
        "example": "2026-06-18T09:30:00Z"
      },
      "notes": {
        "type": "string",
        "title": "Notes",
        "example": "Sample arrived intact; logged into chain-of-custody register."
      }
    },
    "required": [
      "initial_sample",
      "received_at"
    ]
  },
  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      {
        "type": "Control",
        "scope": "#/properties/initial_sample"
      },
      {
        "type": "Control",
        "scope": "#/properties/received_at"
      },
      {
        "type": "Control",
        "scope": "#/properties/notes",
        "options": {
          "multi": true
        }
      }
    ]
  }
}