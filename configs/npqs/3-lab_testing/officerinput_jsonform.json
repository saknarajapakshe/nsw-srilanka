{
  "id": "npqs-lab-testing--officer-form",
  "title": "Laboratory Test Results",
  "schema": {
    "type": "object",
    "properties": {
      "sample_test_result": {
        "type": "string",
        "title": "Laboratory Test Outcome",
        "oneOf": [
          { "const": "pass", "title": "Pass (No Quarantine Pests Found)" },
          { "const": "fail_resubmit", "title": "Fail — Allow Sample Resubmission (First Failure)" },
          { "const": "fail_final", "title": "Fail Final — Reject Consignment (Second Failure)" }
        ],
        "default": "pass"
      },
      "lab_comments": {
        "type": "string",
        "title": "Laboratory Analysis Details",
        "example": "Entomology and pathology tests completed. Nil pests detected."
      },
      "lab_report_attachment_url": {
        "type": "string",
        "format": "file",
        "title": "Uploaded Lab Test Report",
        "example": "https://nsw.gov.lk/storage/reports/lab-report-2026.pdf"
      },
      "post_lab_visual_required": {
        "type": "boolean",
        "title": "Visual Inspection Required for Lab Tested Consignment (Airport PQS Officer)",
        "default": false
      }
    },
    "required": [
      "sample_test_result"
    ]
  },
  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      { "type": "Control", "scope": "#/properties/sample_test_result" },
      { "type": "Control", "scope": "#/properties/lab_comments" },
      { "type": "Control", "scope": "#/properties/lab_report_attachment_url" },
      { "type": "Control", "scope": "#/properties/post_lab_visual_required" }
    ]
  }
}
