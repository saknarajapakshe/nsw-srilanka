{
  "id": "npqs-review-treatment-certs--officer-form",
  "title": "Review Treatment Certificate Documents",
  "schema": {
    "type": "object",
    "properties": {
      "treatment_review_result": {
        "type": "string",
        "title": "Verification Result",
        "oneOf": [
          { "const": "pass", "title": "Pass (Certificates are valid and correct)" },
          { "const": "needs_more_info", "title": "Needs More Info (Request re-upload with corrections)" }
        ],
        "default": "pass"
      },
      "review_comments": {
        "type": "string",
        "title": "Verification Notes / Feedback",
        "example": "Reviewed the uploaded treatment certificate. The chemical, dosage, and duration match standard requirements."
      },
      "post_treatment_visual_required": {
        "type": "boolean",
        "title": "Visual Inspection Required for Treated Consignment (Airport PQS Officer)",
        "default": false
      }
    },
    "required": [
      "treatment_review_result"
    ]
  },
  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      { "type": "Control", "scope": "#/properties/treatment_review_result" },
      { "type": "Control", "scope": "#/properties/review_comments" },
      { "type": "Control", "scope": "#/properties/post_treatment_visual_required" }
    ]
  }
}
