{
  "id": "npqs-pay-certificate-fee--select-method-form",
  "title": "Select Payment Gateway",
  "schema": {
    "type": "object",
    "properties": {
      "selected_method": {
        "type": "string",
        "title": "Payment Provider",
        "oneOf": [
          {
            "const": "govpay",
            "title": "GovPay Sandbox (Mock checkout)"
          }
        ],
        "default": "govpay"
      }
    },
    "required": [
      "selected_method"
    ]
  },
  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      {
        "type": "Control",
        "scope": "#/properties/selected_method"
      }
    ]
  }
}