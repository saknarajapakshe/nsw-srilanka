# API Configuration
VITE_API_BASE_URL=http://localhost:8080

# Identity Provider (Asgardeo/Thunder)
VITE_IDP_BASE_URL=https://localhost:8090
VITE_IDP_CLIENT_ID=TRADER_PORTAL_APP
VITE_APP_URL=http://localhost:5173
VITE_IDP_SCOPES=openid,profile,email,group
VITE_IDP_PLATFORM=AsgardeoV2
VITE_IDP_TRADER_GROUP_NAME=Traders
VITE_IDP_CHA_GROUP_NAME=CHA

# Feature Flags
VITE_SHOW_AUTOFILL_BUTTON=true
# Switches the task detail screen to the zone-based renderer (ZoneView wire
# shape, derived interactivity, per-zone handles). Default: false (legacy
# RenderInfo path). See docs/architecture/render-json.md.
VITE_USE_ZONE_RENDERER=true

# Development
# VITE_API_BASE_URL=http://localhost:8080

# Production
# VITE_API_BASE_URL=https://api.production.com
# VITE_IDP_BASE_URL=https://idp.production.com
# VITE_IDP_CLIENT_ID=your-production-client-id
# VITE_APP_URL=https://trader.production.com
# VITE_IDP_SCOPES=openid,profile,email
# VITE_IDP_PLATFORM=AsgardeoV2
