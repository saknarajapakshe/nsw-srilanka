# Copy this file to .env and adjust values for your local environment.

# Database Configuration
DB_HOST=localhost
# Mostly 5432 for local Postgres, let's use a different port to avoid conflicts with any existing local Postgres instances
DB_PORT=55432  
DB_USERNAME=postgres
DB_PASSWORD=changeme
DB_NAME=nsw_db
# Use 'require' in production to enforce SSL connections to the database
DB_SSLMODE=disable
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_MAX_CONN_LIFETIME_SECONDS=3600

# Server Configuration
SERVER_PORT=8080
SERVER_DEBUG=true
SERVER_LOG_LEVEL=info
SERVICE_URL=http://localhost:8080

# Config file paths (relative to the working directory at start-up)
# Docker development can use a different config file with hostnames adjusted for the container network
# SERVICES_CONFIG_PATH=./configs/services.docker.json
SERVICES_CONFIG_PATH=./configs/services.json
PAYMENT_METHODS_CONFIG_PATH=./configs/payment_methods.json

# CORS Configuration
# Here Agency Portals also added. because they are using the storage service directly from the portals
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:5177
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=3600

# Storage Configuration
STORAGE_TYPE=local
# Options: 'local' or 's3'
STORAGE_LOCAL_BASE_DIR=./bucket
# Optional local storage tuning
# STORAGE_LOCAL_PUT_SECRET=local-dev-secret
# STORAGE_LOCAL_PUBLIC_URL=http://localhost:8080
# STORAGE_PRESIGN_TTL=15m

# S3 Configuration (only needed when STORAGE_TYPE=s3)
# STORAGE_S3_ENDPOINT=
# STORAGE_S3_BUCKET=nsw-uploads
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_ACCESS_KEY=
# STORAGE_S3_SECRET_KEY=
# STORAGE_S3_USE_SSL=true
# STORAGE_S3_PUBLIC_URL=

# Authentication Configuration
AUTH_JWKS_URL=https://localhost:8090/oauth2/jwks
AUTH_ISSUER=https://localhost:8090
AUTH_CLIENT_IDS=TRADER_PORTAL_APP,FCAU_TO_NSW,NPQS_TO_NSW,IRD_TO_NSW
AUTH_AUDIENCE=NSW_API
# In local development with self-signed certs, we may need to skip TLS verification for the JWKS endpoint.
AUTH_JWKS_INSECURE_SKIP_VERIFY=true

# Temporal Configuration
TEMPORAL_HOST=localhost
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=default

# Multi-Repository Local Workspace Configuration (optional)
# Set GOWORK to '/src/go.work' to use local sibling directories instead of GitHub remote dependencies.
# GOWORK=/src/go.work
# NSW_PATH=../nsw
# NSW_TASK_FLOW_PATH=../nsw-task-flow
# GO_TEMPORAL_WORKFLOW_PATH=../go-temporal-workflow
