{
  "name": "trade_up_to_hscode",
  "steps": [
    {
      "name": "trader creates consignment",
      "request": {
        "actor": "trader",
        "method": "POST",
        "path": "/api/v1/consignments",
        "expectStatus": 201,
        "extract": { "consignmentId": "id" }
      }
    },
    {
      "name": "wait for Initialize Consignment task",
      "wait": {
        "node": "Initialize Consignment",
        "state": "IN_PROGRESS",
        "into": "initTask",
        "timeout": "45s"
      }
    },
    {
      "name": "trader initializes consignment (name + CHA)",
      "request": {
        "actor": "trader",
        "method": "POST",
        "path": "/api/v1/tasks/{{initTask}}/command/submit",
        "body": { "consignment_name": "E2E Replay Consignment", "cha_company_id": "adam-pvt-ltd" },
        "expectStatus": 204
      }
    },
    {
      "name": "wait for HS-code selection task",
      "wait": {
        "node": "Select HS Codes",
        "state": "IN_PROGRESS",
        "into": "hsTask",
        "timeout": "45s"
      }
    },
    {
      "name": "trader selects HS codes (FCAU flow)",
      "request": {
        "actor": "trader",
        "method": "POST",
        "path": "/api/v1/tasks/{{hsTask}}/command/submit",
        "body": { "hs_codes": ["fcau-health-certificate-reg"] },
        "expectStatus": 204
      }
    },
    {
      "name": "wait for FCAU application to start (agency split fired)",
      "wait": {
        "node": "[FCAU] Apply for Health Certificate",
        "state": "IN_PROGRESS",
        "timeout": "60s"
      }
    }
  ]
}
